#!/bin/bash
# Notify when BAT0 is at/under 15% while discharging. Notification persists
# (re-sent each loop with -t 0) until the laptop is plugged in.

THRESHOLD=15
notif_id=0

while true; do
    capacity=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
    status=$(cat /sys/class/power_supply/BAT0/status 2>/dev/null)

    if [ -n "$capacity" ] && [ "$status" = "Discharging" ] && [ "$capacity" -le "$THRESHOLD" ]; then
        notif_id=$(notify-send -p -u critical -t 0 -r "$notif_id" \
            "Battery low" "Battery at ${capacity}% — plug in.")
    elif [ "$notif_id" -ne 0 ]; then
        makoctl dismiss -n "$notif_id" 2>/dev/null
        notif_id=0
    fi

    sleep 30
done
