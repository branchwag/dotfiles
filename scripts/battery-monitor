#!/bin/bash
# Notify when BAT0 drops to <=15% while discharging. Re-arms once it goes back above 15% or starts charging.

THRESHOLD=15
notified=0

while true; do
    capacity=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
    status=$(cat /sys/class/power_supply/BAT0/status 2>/dev/null)

    if [ -n "$capacity" ] && [ "$status" = "Discharging" ] && [ "$capacity" -le "$THRESHOLD" ]; then
        if [ "$notified" -eq 0 ]; then
            notify-send -u critical "Battery low" "Battery at ${capacity}% — plug in soon."
            notified=1
        fi
    else
        notified=0
    fi

    sleep 60
done
